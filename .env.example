# ============================================
# FraternityOS Environment Variables
# ============================================
# Copy to .env and fill in values.
# Optional: symlink or copy sensitive values from secrets/ (gitignored); see secrets/.gitkeep.
# DB schema: python scripts/migrate_db.py (requires DATABASE_URL).

# -- Local Dev (PostgreSQL via Docker) --
DATABASE_URL=postgresql://fraternityos:localdev@localhost:5434/fraternityos
JWT_SECRET=local-dev-secret-key-change-in-prod
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:8000
CHECKIN_LINK_TTL_MINUTES=10

# -- Production (Supabase) --
# Uncomment and fill in for Supabase deployment:
# Direct Postgres (required for FastAPI, Alembic, scripts/seed.py):
#   Dashboard → Project Settings → Database → Connection string → URI
#   Replace [YOUR-PASSWORD] with the database password (not the anon key).
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# FRONTEND_URL=https://your-app.vercel.app
# BASE_URL=https://your-app.vercel.app

# -- Frontend (fratos/.env.local) --
# Local: point at uvicorn (see fratos/.env.local — NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000).
# Vercel: omit NEXT_PUBLIC_API_BASE so requests use same-origin /api.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the dashboard "publishable" key or legacy anon key (helpers accept both):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
