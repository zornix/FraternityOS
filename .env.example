# ============================================
# FraternityOS Environment Variables
# ============================================
# Copy to .env and fill in values.

# -- Local Dev (PostgreSQL via Docker) --
DATABASE_URL=postgresql://fraternityos:localdev@localhost:5434/fraternityos
JWT_SECRET=local-dev-secret-key-change-in-prod
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:8000
CHECKIN_LINK_TTL_MINUTES=10

# -- Production (Supabase) --
# Uncomment and fill in for Supabase deployment:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# FRONTEND_URL=https://your-app.vercel.app
# BASE_URL=https://your-app.vercel.app

# -- Frontend (fratos/.env.local) --
# Local: point at uvicorn (see fratos/.env.local — NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000).
# Vercel: omit NEXT_PUBLIC_API_BASE so requests use same-origin /api.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
