# ============================================
# FraternityOS Environment Variables
# ============================================
# Copy to .env and fill in values.
# For local dev the defaults below work out of the box with docker-compose.

# -- Database --
# Local Docker (default):
DATABASE_URL=postgresql://fraternityos:localdev@localhost:5434/fraternityos
# Production (Supabase direct Postgres):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# -- Auth --
JWT_SECRET=local-dev-secret-key-change-in-prod

# -- URLs --
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:8001

# -- Check-in link TTL (minutes) --
CHECKIN_LINK_TTL_MINUTES=10

# -- Frontend (fratos/.env.local) --
# Local: NEXT_PUBLIC_API_BASE=http://127.0.0.1:8001
# Production: omit (same-origin /api routing)
