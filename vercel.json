{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "fratos/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/c/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/fratos/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-fines",
      "schedule": "*/15 * * * *"
    }
  ]
}
